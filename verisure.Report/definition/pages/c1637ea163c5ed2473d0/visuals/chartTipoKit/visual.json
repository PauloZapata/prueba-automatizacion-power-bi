{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.4.0/schema.json",
  "name": "chartTipoKit",
  "position": {
    "x": 20,
    "y": 620,
    "z": 10,
    "width": 600,
    "height": 250,
    "tabOrder": 10
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": { "Entity": "TB_FIN_ANALISIS" }
                  },
                  "Property": "TIPOKIT"
                }
              },
              "queryRef": "TB_FIN_ANALISIS.TIPOKIT",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Aggregation": {
                  "Expression": {
                    "Column": {
                      "Expression": {
                        "SourceRef": { "Entity": "TB_FIN_ANALISIS" }
                      },
                      "Property": "contrato"
                    }
                  },
                  "Function": 5
                }
              },
              "queryRef": "CountNonBlank(TB_FIN_ANALISIS.contrato)",
              "active": true
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": true,
            "text": "Top Tipos de Kit por Contratos",
            "fontSize": 11
          }
        }
      ],
      "background": [
        {
          "properties": {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": true,
            "color": { "solid": { "color": "#E0E0E0" } },
            "radius": 8
          }
        }
      ],
      "dropShadow": [
        {
          "properties": {
            "show": true,
            "preset": "BottomRight",
            "color": { "solid": { "color": "#000000" } },
            "transparency": 90,
            "shadowSpread": 0,
            "shadowBlur": 8,
            "angle": 315,
            "shadowDistance": 4
          }
        }
      ]
    },
    "objects": {
      "categoryAxis": [
        {
          "properties": {
            "show": true,
            "showAxisTitle": false
          }
        }
      ],
      "valueAxis": [
        {
          "properties": {
            "show": true,
            "showAxisTitle": false,
            "gridlineShow": false
          }
        }
      ],
      "labels": [
        {
          "properties": {
            "show": true,
            "fontSize": 9
          }
        }
      ],
      "legend": [
        {
          "properties": {
            "show": false
          }
        }
      ]
    }
  }
}
