{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.4.0/schema.json",
  "name": "headerBackground",
  "position": {
    "x": 0,
    "y": 0,
    "z": 0,
    "width": 1280,
    "height": 70,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "shape",
    "objects": {
      "fill": [
        {
          "properties": {
            "show": true,
            "fillColor": { "solid": { "color": "#D32F2F" } }
          }
        }
      ],
      "line": [
        {
          "properties": {
            "show": false
          }
        }
      ]
    }
  }
}
